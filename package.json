{
  "name": "docs-ssh",
  "version": "0.1.0",
  "description": "Self-hosted SSH docs server for Supabase, Cloudflare and Postgres",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "fetch-docs": "node --import tsx/esm src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:bench": "vitest run --config vitest.bench.config.ts",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "simple-git": "^3.0.0",
    "turndown": "^7.2.0",
    "@types/turndown": "^5.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
