{
  "name": "docs-ssh",
  "version": "0.4.1",
  "description": "Self-hosted SSH docs server serving 18 documentation sources as searchable markdown over SSH",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "fetch-docs": "node --import tsx/esm src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:bench": "vitest run --config vitest.bench.config.ts",
    "lint": "tsc --noEmit",
    "generate:tools": "node --import tsx/esm src/commands/generate-tools-sh.ts",
    "docker:build": "DOCS_OUT_DIR=./docs DOCS_WORK_DIR=/tmp/docs-ssh-work node --import tsx/esm src/index.ts && docker build --build-arg DOCS_PREBUILT=true -t docs-ssh:local . && rm -rf ./docs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "turndown": "^7.2.0"
  },
  "engines": {
    "node": ">=22"
  }
}
