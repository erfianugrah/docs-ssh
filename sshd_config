Port 2222
ListenAddress 0.0.0.0

# Host keys — generated at runtime in tmpfs, unique per container instance
HostKey /run/sshd/ssh_host_ed25519_key
HostKey /run/sshd/ssh_host_rsa_key

# ─── Post-quantum key exchange ──────────────────────────────────────
# Prefer hybrid post-quantum KEX (sntrup761 + curve25519) to defend against
# "store now, decrypt later" attacks.  Falls back to curve25519 for clients
# that don't support it yet (e.g. ssh2 npm, older OpenSSH < 9.0).
KexAlgorithms sntrup761x25519-sha512@openssh.com,curve25519-sha256,curve25519-sha256@libssh.org

# Strongest ciphers only — chacha20 first (constant-time), then AES-GCM
Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com

# Encrypt-then-MAC only — drop legacy MAC algorithms
MACs hmac-sha2-256-etm@openssh.com,hmac-sha2-512-etm@openssh.com

# Only allow ed25519 host keys for authentication (strongest, smallest)
HostKeyAlgorithms ssh-ed25519,rsa-sha2-512,rsa-sha2-256

# Passwordless access — by design (public docs server, like supabase.sh)
PasswordAuthentication yes
PermitEmptyPasswords yes
PubkeyAuthentication no
PermitRootLogin no

# Restrict to docs user only
AllowUsers docs

# Allow PTY for interactive sessions (colors, prompt); agents use exec mode
PermitTTY yes

# All commands go through the audit logger
ForceCommand /usr/local/bin/log-cmd

# Idle connection cleanup
ClientAliveInterval 30
ClientAliveCountMax 3

# Connection limits
MaxStartups 50:30:100
LoginGraceTime 15
MaxSessions 5

# Exempt the Docker gateway / Caddy L4 proxy from per-source penalties.
# All connections arrive from the proxy IP, so penalising it blocks everyone.
PerSourcePenaltyExemptList 172.16.0.0/12

# Suppress failed-auth noise from bot scans (AllowUsers docs rejects them).
# ERROR level only logs fatal issues, not every rejected username.
LogLevel ERROR

# Performance
UseDNS no
PrintMotd no
