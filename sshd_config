Port 2222
ListenAddress 0.0.0.0

# Host keys — generated at runtime in tmpfs, unique per container instance
HostKey /run/sshd/ssh_host_ed25519_key
HostKey /run/sshd/ssh_host_rsa_key

# Passwordless access — by design (public docs server, like supabase.sh)
PasswordAuthentication yes
PermitEmptyPasswords yes
PubkeyAuthentication no
PermitRootLogin no

# Restrict to docs user only
AllowUsers docs

# Disable PTY for exec-only usage (interactive shell still works via ForceCommand)
PermitTTY yes

# All commands go through the audit logger
ForceCommand /usr/local/bin/log-cmd

# Idle connection cleanup
ClientAliveInterval 30
ClientAliveCountMax 3

# Connection limits
MaxStartups 50:30:100
LoginGraceTime 15
MaxSessions 5

# Performance
UseDNS no
PrintMotd no
